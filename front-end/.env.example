# BillSutra frontend environment template
# Copy this file to front-end/.env.local and replace placeholders with real values.

APP_ENV=production
NODE_ENV=production

# NextAuth
NEXTAUTH_URL=https://app.example.com
NEXTAUTH_SECRET=replace-with-a-long-random-secret

# Public URLs
NEXT_PUBLIC_APP_URL=https://app.example.com

# Backend base URL. Preferred variable:
NEXT_PUBLIC_BACKEND_URL=https://api.example.com

# Legacy alias still supported for compatibility.
# If you use it, set the full /api URL.
NEXT_PUBLIC_API_URL=https://api.example.com/api

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Product analytics / observability
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_ANALYTICS_OPT_OUT_DEFAULT=false
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
NEXT_PUBLIC_SENTRY_RELEASE=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Auth UX flags
NEXT_PUBLIC_USE_SECURE_AUTH=true
NEXT_PUBLIC_USE_COOKIE_AUTH=true
NEXT_PUBLIC_USE_DYNAMIC_STATUS=true

# PDF rendering (server runtime inside Next.js)
PDF_RENDER_ORIGIN=https://app.example.com
PDF_RENDER_TIMEOUT_MS=60000
PDF_RENDER_RETRIES=1
PDF_RENDER_RETRY_DELAY_MS=300

# Optional browser overrides for self-hosted PDF rendering
CHROME_BIN=
CHROME_PATH=
PUPPETEER_EXECUTABLE_PATH=
BROWSER_EXECUTABLE_PATH=

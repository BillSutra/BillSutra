  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mongoose": "^5.11.96",
    "@types/node": "^24.3.0",
    "@types/nodemailer": "^8.0.0",
    "concurrently": "^9.2.0",
    "nodemon": "^3.1.10",
    "prisma": "^6.18.0",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@prisma/client": "^6.18.0",
    "@sentry/node": "^10.45.0",
    "@simplewebauthn/server": "^13.3.0",

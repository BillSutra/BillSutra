{
  "name": "express_ts",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "worker": "tsx src/queues/worker.ts",
    "worker:dev": "tsx watch src/queues/worker.ts",
    "worker:start": "node dist/queues/worker.js",
    "watch": "tsc -w",
    "dev": "tsx watch src/index.ts",
    "test:database-url": "tsx --test src/config/databaseUrl.test.ts",
    "test:redis-config": "tsx --test src/config/redisConfig.test.ts",
    "test:security-env": "tsx --test src/lib/securityEnv.test.ts",
    "test:assistant-parser": "tsx --test src/modules/assistant/assistant.parser.test.ts",
    "test:assistant-integration": "tsx --test src/modules/assistant/assistant.integration.test.ts",
    "test:assistant-chatflow": "tsx --test src/modules/assistant/assistant.chatflow.e2e.test.ts",
    "test:subscription-access": "tsx --test src/config/subscriptionPlans.matrix.test.ts src/routes/subscriptionAccess.contract.test.ts",
    "test:settings-security": "tsx --test src/routes/settingsSecurity.contract.test.ts",
    "face:audit": "tsx src/scripts/auditFaceEmbeddings.ts",
    "face:migrate": "tsx src/scripts/migrateFaceEncodings.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "seed": "prisma db seed"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "keywords": [],

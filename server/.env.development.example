APP_ENV=development
NODE_ENV=development
PORT=8000
TRUST_PROXY=false
ENABLE_SCHEDULER=true
GRACEFUL_SHUTDOWN_TIMEOUT_MS=15000
UPLOADS_ROOT=./uploads


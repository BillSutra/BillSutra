APP_ENV=development
NODE_ENV=development
PORT=8000
TRUST_PROXY=false
ENABLE_SCHEDULER=true
GRACEFUL_SHUTDOWN_TIMEOUT_MS=15000
UPLOADS_ROOT=./uploads

FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

USE_SECURE_AUTH=true
USE_COOKIE_AUTH=true
USE_DYNAMIC_STATUS=true
AUTH_COOKIE_SECURE=auto
AUTH_COOKIE_SAMESITE=lax

USE_REDIS_CACHE=false
USE_REDIS_RATE_LIMIT=false
USE_QUEUE=false

SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_SLOW_REQUEST_THRESHOLD_MS=1200

WEBAUTHN_ORIGIN=http://localhost:3000
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=BillSutra Local

FACE_SERVICE_URL=http://localhost:5001

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                Int     @id @default(autoincrement())
  name              String  @db.VarChar(191)
  email             String  @unique @db.VarChar(191)
  password_hash     String?
  provider          String  @default("credentials")
  oauth_id          String?
  image             String?
  is_email_verified Boolean @default(false)
  email_verified_at DateTime?

  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  customers                   Customer[]
  suppliers                   Supplier[]
  categories                  Category[]
  products                    Product[]
  warehouses                  Warehouse[]
  purchases                   Purchase[]
  sales                       Sale[]
  invoices                    Invoice[]
  recurring_invoice_templates RecurringInvoiceTemplate[]
  financial_goals             FinancialGoal[]
  payments                    Payment[]
  access_payments             AccessPayment[]
  subscription                Subscription?
  subscription_usage          SubscriptionUsage[]
  resets                      PasswordResetToken[]
  refresh_tokens              RefreshToken[]
  uploaded_files              UploadedFile[]
  business_profile            BusinessProfile?
  user_templates              UserTemplate[]
  user_saved_templates        UserSavedTemplate[]
  export_logs                 ExportLog[]
  passkey_credentials         PasskeyCredential[]
  auth_challenges             AuthChallenge[]
  otp_codes                   OtpCode[]
  auth_events                 AuthEvent[]
  audit_logs                  AuditLog[]
  face_data                   FaceData?
  preferences                 UserPreference?
  notifications               Notification[]
  extra_entries               ExtraEntry[]
  analytics_daily_stats       AnalyticsDailyStat[]
  email_verification_tokens   EmailVerificationToken[]
  email_logs                  EmailLog[]

  session_version Int @default(0)
  password_changed_at DateTime?

  @@map("users")
}

model UserPreference {
  id Int @id @default(autoincrement())

  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int  @unique

  language    String @default("en") @db.VarChar(10)
  currency    String @default("INR") @db.VarChar(10)
  date_format String @default("DD/MM/YYYY") @db.VarChar(32)

  notification_payment_reminders  Boolean @default(true)
  notification_low_stock_alerts   Boolean @default(true)
  notification_due_invoice_alerts Boolean @default(true)
  email_payment_reminders_enabled Boolean @default(true)
  email_payment_reminder_offsets  String  @default("1,3,7") @db.VarChar(64)
  email_weekly_reports_enabled    Boolean @default(true)
  email_low_stock_alerts_enabled  Boolean @default(true)
  allowNegativeStock              Boolean @default(true) @map("allow_negative_stock")

  backup_auto_enabled Boolean @default(false)

  branding_template_id Int?
  branding_theme_color String? @db.VarChar(16)
  branding_terms       String?
  branding_signature   String? @db.VarChar(191)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("user_preferences")
}

model Notification {
  id String @id @default(cuid()) @db.VarChar(191)

  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int

  business_id String @db.VarChar(191)
  type        NotificationType
  title       String?  @db.VarChar(191)
  message     String   @db.VarChar(500)
  action_url  String?  @db.VarChar(255)
  priority    String   @default("info") @db.VarChar(16)
  is_read     Boolean  @default(false)
  reference_key String? @db.VarChar(191)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([user_id, created_at])
  @@index([user_id, is_read, created_at])
  @@index([user_id, type, created_at])
  @@index([user_id, priority, created_at])
  @@index([business_id, created_at])
  @@unique([business_id, reference_key])
  @@map("notifications")
}

model Admin {
  id        String   @id @default(cuid()) @db.VarChar(191)
  email     String   @unique @db.VarChar(191)
  password  String   @db.VarChar(191)
  role      String   @default("SUPER_ADMIN") @db.VarChar(32)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("admins")
}

model Business {
  id        String   @id @default(cuid()) @db.VarChar(191)
  name      String   @db.VarChar(191)
  ownerId   String   @unique @map("owner_id") @db.VarChar(191)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workers Worker[]

  @@map("businesses")
}

model Worker {
  id         String     @id @default(cuid()) @db.VarChar(191)
  email      String     @unique @db.VarChar(191)
  name       String     @db.VarChar(191)
  phone      String?    @unique @db.VarChar(191)
  imageUrl   String?    @map("image_url") @db.VarChar(255)
  password   String     @db.VarChar(191)
  role       WorkerRole @default(WORKER)
  businessId String     @map("business_id") @db.VarChar(191)
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  sales    Sale[]
  invoices Invoice[]

  @@index([businessId])
  @@index([businessId, createdAt])
  @@map("workers")
}

model BusinessProfile {
  id                   Int      @id @default(autoincrement())
  user                 User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id              Int      @unique
  business_name        String   @db.VarChar(191)
  address              String?
  address_line1        String?  @db.VarChar(191)
  city                 String?  @db.VarChar(191)
  state                String?  @db.VarChar(191)
  pincode              String?  @db.VarChar(10)
  phone                String?
  email                String?
  website              String?
  logo_url             String?
  tax_id               String?
  currency             String   @default("INR") @db.VarChar(10)
  show_logo_on_invoice Boolean  @default(true)
  show_tax_number      Boolean  @default(true)
  show_payment_qr      Boolean  @default(false)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  @@index([user_id])
  @@map("business_profiles")
}

model Template {
  id            Int      @id @default(autoincrement())
  name          String   @unique @db.VarChar(191)
  description   String?
  layout_config Json
  created_at    DateTime @default(now())

  sections             TemplateSection[]
  user_settings        UserTemplate[]
  user_saved_templates UserSavedTemplate[]

  @@map("templates")
}

model TemplateSection {
  id            Int      @id @default(autoincrement())
  template      Template @relation(fields: [template_id], references: [id], onDelete: Cascade)
  template_id   Int
  section_key   String   @db.VarChar(120)
  section_order Int
  is_default    Boolean  @default(true)

  @@index([template_id])
  @@map("template_sections")
}

model UserTemplate {
  id               Int      @id @default(autoincrement())
  user             User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id          Int
  template         Template @relation(fields: [template_id], references: [id], onDelete: Cascade)
  template_id      Int
  enabled_sections String[]
  theme_color      String?
  section_order    String[]
  design_config    Json?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@unique([user_id, template_id])
  @@index([user_id])
  @@index([template_id])
  @@map("user_templates")
}

model UserSavedTemplate {
  id               Int       @id @default(autoincrement())
  user             User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id          Int
  name             String    @db.VarChar(191)
  base_template    Template? @relation(fields: [base_template_id], references: [id], onDelete: SetNull)
  base_template_id Int?
  enabled_sections String[]
  section_order    String[]
  theme_color      String?
  design_config    Json?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  @@index([user_id])
  @@index([base_template_id])
  @@map("user_saved_templates")
}

model FinancialGoal {
  id                          Int       @id @default(autoincrement())
  user                        User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id                     Int
  title                       String    @db.VarChar(191)
  emoji                       String?   @db.VarChar(32)
  target_amount               Decimal   @db.Decimal(12, 2)
  current_amount              Decimal   @default(0) @db.Decimal(12, 2)
  monthly_contribution_target Decimal?  @db.Decimal(12, 2)
  target_date                 DateTime?
  created_at                  DateTime  @default(now())
  updated_at                  DateTime  @updatedAt

  @@index([user_id])
  @@map("financial_goals")
}

model ExtraEntry {
  id        String    @id @default(cuid()) @db.VarChar(191)
  title     String    @db.VarChar(191)
  amount    Decimal   @db.Decimal(12, 2)
  type      EntryType
  date      DateTime
  notes     String?   @db.VarChar(500)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int       @map("user_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@index([userId, date])
  @@map("extra_entries")
}

model AnalyticsDailyStat {
  id Int @id @default(autoincrement())

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int  @map("user_id")

  date DateTime

  bookedSales         Decimal @default(0) @map("booked_sales") @db.Decimal(14, 2)
  collectedSales      Decimal @default(0) @map("collected_sales") @db.Decimal(14, 2)
  pendingSales        Decimal @default(0) @map("pending_sales") @db.Decimal(14, 2)
  saleCount           Int     @default(0) @map("sale_count")
  invoiceBilled       Decimal @default(0) @map("invoice_billed") @db.Decimal(14, 2)
  invoiceCount        Int     @default(0) @map("invoice_count")
  invoiceCollections  Decimal @default(0) @map("invoice_collections") @db.Decimal(14, 2)
  invoicePending      Decimal @default(0) @map("invoice_pending") @db.Decimal(14, 2)
  bookedPurchases     Decimal @default(0) @map("booked_purchases") @db.Decimal(14, 2)
  cashOutPurchases    Decimal @default(0) @map("cash_out_purchases") @db.Decimal(14, 2)
  pendingPurchases    Decimal @default(0) @map("pending_purchases") @db.Decimal(14, 2)
  purchaseCount       Int     @default(0) @map("purchase_count")
  expenses            Decimal @default(0) @db.Decimal(14, 2)
  extraIncome         Decimal @default(0) @map("extra_income") @db.Decimal(14, 2)
  extraExpense        Decimal @default(0) @map("extra_expense") @db.Decimal(14, 2)
  extraLoss           Decimal @default(0) @map("extra_loss") @db.Decimal(14, 2)
  extraInvestment     Decimal @default(0) @map("extra_investment") @db.Decimal(14, 2)
  customersCreated    Int     @default(0) @map("customers_created")
  suppliersCreated    Int     @default(0) @map("suppliers_created")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@unique([userId, date])
  @@index([userId, date])
  @@index([userId, updatedAt])
  @@map("analytics_daily_stats")
}

model Customer {
  id      Int  @id @default(autoincrement())
  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int

  name    String  @db.VarChar(191)
  email   String?
  phone   String?
  address String?

  customer_type   String   @default("individual") @db.VarChar(32)
  business_name   String?  @db.VarChar(191)
  gstin           String?  @db.VarChar(15)
  address_line1   String?  @db.VarChar(191)
  city            String?  @db.VarChar(191)
  state           String?  @db.VarChar(191)
  pincode         String?  @db.VarChar(10)
  notes           String?  @db.VarChar(500)
  credit_limit    Decimal? @db.Decimal(12, 2)
  payment_terms   String?  @db.VarChar(32)
  opening_balance Decimal  @default(0) @db.Decimal(12, 2)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  invoices                    Invoice[]
  recurring_invoice_templates RecurringInvoiceTemplate[]
  sales                       Sale[]
  email_logs                  EmailLog[]

  @@index([user_id])
  @@index([user_id, created_at])
  @@map("customers")
}

model Supplier {
  id      Int  @id @default(autoincrement())
  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int

  name       String
  email      String?
  phone      String?
  address    String?
  categories String[] @default([])

  business_name   String? @db.VarChar(191)
  gstin           String? @db.VarChar(15)
  pan             String? @db.VarChar(10)
  address_line1   String? @db.VarChar(191)
  city            String? @db.VarChar(191)
  state           String? @db.VarChar(191)
  pincode         String? @db.VarChar(10)
  payment_terms   String? @db.VarChar(32)
  opening_balance Decimal @default(0) @db.Decimal(12, 2)
  notes           String? @db.VarChar(500)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  purchases Purchase[]

  @@index([user_id])
  @@index([user_id, created_at])
  @@map("suppliers")
}

model Category {
  id Int @id @default(autoincrement())

  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int

  name String

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  products Product[]

  @@unique([user_id, name])
  @@index([user_id])
  @@index([user_id, created_at])
  @@map("categories")
}

model Product {
  id Int @id @default(autoincrement())

  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int

  category    Category? @relation(fields: [category_id], references: [id], onDelete: SetNull)
  category_id Int?

  name    String
  sku     String
  barcode String?

  price Decimal  @db.Decimal(12, 2)
  cost  Decimal? @db.Decimal(12, 2)

  gst_rate Decimal @default(18) @db.Decimal(5, 2)

  stock_on_hand Int @default(0)
  reorder_level Int @default(0)
  lastAutoCorrectedAt DateTime? @map("last_auto_corrected_at")

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  purchaseItems PurchaseItem[]
  saleItems     SaleItem[]
  invoiceItems  InvoiceItem[]
  movements     StockMovement[]
  inventories   Inventory[]
  inventoryIssues InventoryIssue[]

  @@unique([user_id, barcode])
  @@unique([user_id, sku])
  @@index([user_id])
  @@index([category_id])
  @@index([user_id, name])
  @@index([user_id, category_id])
  @@map("products")
}

model InventoryIssue {
  id Int @id @default(autoincrement())

  product    Product @relation(fields: [product_id], references: [id], onDelete: Cascade)
  product_id Int

  type     InventoryIssueType
  quantity Int
  resolved Boolean  @default(false)
  metadata Json?
  resolved_at DateTime?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([product_id, resolved, type])
  @@index([resolved, created_at])
  @@map("inventory_issues")
}

model Warehouse {
  id Int @id @default(autoincrement())

  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int

  name     String
  location String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  inventories Inventory[]
  purchases   Purchase[]

  @@index([user_id])
  @@map("warehouses")
}

model Inventory {
  id Int @id @default(autoincrement())

  warehouse    Warehouse @relation(fields: [warehouse_id], references: [id], onDelete: Cascade)
  warehouse_id Int

  product    Product @relation(fields: [product_id], references: [id], onDelete: Cascade)
  product_id Int

  quantity Int @default(0)

  @@unique([warehouse_id, product_id])
  @@map("inventories")
}

model Purchase {
  id Int @id @default(autoincrement())

  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int

  supplier    Supplier? @relation(fields: [supplier_id], references: [id], onDelete: SetNull)
  supplier_id Int?

  warehouse    Warehouse? @relation(fields: [warehouse_id], references: [id], onDelete: SetNull)
  warehouse_id Int?

  purchase_date DateTime @default(now())

  subtotal      Decimal        @db.Decimal(12, 2)
  tax           Decimal        @db.Decimal(12, 2)
  total         Decimal        @db.Decimal(12, 2)
  totalAmount   Decimal        @default(0) @map("total_amount") @db.Decimal(12, 2)
  paidAmount    Decimal        @default(0) @map("paid_amount") @db.Decimal(12, 2)
  pendingAmount Decimal        @default(0) @map("pending_amount") @db.Decimal(12, 2)
  paymentStatus PaymentStatus  @default(UNPAID) @map("payment_status")
  paymentDate   DateTime?      @map("payment_date")
  paymentMethod PaymentMethod? @map("payment_method")

  notes String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  items PurchaseItem[]

  @@index([user_id])
  @@index([user_id, purchase_date])
  @@index([user_id, purchase_date, supplier_id])
  @@index([supplier_id])
  @@index([warehouse_id])
  @@map("purchases")
}

model PurchaseItem {
  id Int @id @default(autoincrement())

  purchase    Purchase @relation(fields: [purchase_id], references: [id], onDelete: Cascade)
  purchase_id Int

  product    Product? @relation(fields: [product_id], references: [id])
  product_id Int?

  name       String
  quantity   Int
  unit_cost  Decimal  @db.Decimal(12, 2)
  tax_rate   Decimal? @db.Decimal(5, 2)
  line_total Decimal  @db.Decimal(12, 2)

  @@index([purchase_id])
  @@map("purchase_items")
}

model Sale {
  id Int @id @default(autoincrement())

  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int

  customer    Customer? @relation(fields: [customer_id], references: [id], onDelete: SetNull)
  customer_id Int?

  status SaleStatus @default(COMPLETED)

  sale_date DateTime @default(now())

  subtotal      Decimal        @db.Decimal(12, 2)
  tax           Decimal        @db.Decimal(12, 2)
  total         Decimal        @db.Decimal(12, 2)
  totalAmount   Decimal        @default(0) @map("total_amount") @db.Decimal(12, 2)
  paidAmount    Decimal        @default(0) @map("paid_amount") @db.Decimal(12, 2)
  pendingAmount Decimal        @default(0) @map("pending_amount") @db.Decimal(12, 2)
  paymentStatus PaymentStatus  @default(UNPAID) @map("payment_status")
  paymentDate   DateTime?      @map("payment_date")
  paymentMethod PaymentMethod? @map("payment_method")
  worker         Worker?        @relation(fields: [workerId], references: [id], onDelete: SetNull)
  workerId       String?        @map("worker_id") @db.VarChar(191)

  notes String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  items SaleItem[]

  @@index([user_id])
  @@index([customer_id])
  @@index([user_id, sale_date])
  @@index([user_id, sale_date, customer_id])
  @@index([user_id, paymentDate])
  @@index([workerId])
  @@map("sales")
}

model SaleItem {
  id Int @id @default(autoincrement())

  sale    Sale @relation(fields: [sale_id], references: [id], onDelete: Cascade)
  sale_id Int

  product    Product? @relation(fields: [product_id], references: [id])
  product_id Int?

  name     String
  quantity Int
  nonInventoryItem Boolean @default(false) @map("non_inventory_item")

  unit_price Decimal  @db.Decimal(12, 2)
  tax_rate   Decimal? @db.Decimal(5, 2)

  line_total Decimal @db.Decimal(12, 2)

  @@index([sale_id])
  @@map("sale_items")
}

model Invoice {
  id Int @id @default(autoincrement())

  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int

  customer    Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  customer_id Int

  invoice_number String @db.VarChar(32)
  warehouse_id   Int?
  stock_applied  Boolean @default(false)

  status InvoiceStatus @default(DRAFT)

  date     DateTime  @default(now()) @map("issue_date")
  due_date DateTime?

  subtotal Decimal @db.Decimal(12, 2)
  total_base Decimal @default(0) @map("total_base") @db.Decimal(12, 2)
  tax      Decimal @db.Decimal(12, 2)
  tax_mode String  @default("CGST_SGST") @map("tax_mode") @db.VarChar(32)
  total_cgst Decimal @default(0) @map("total_cgst") @db.Decimal(12, 2)
  total_sgst Decimal @default(0) @map("total_sgst") @db.Decimal(12, 2)
  total_igst Decimal @default(0) @map("total_igst") @db.Decimal(12, 2)
  discount Decimal @default(0) @db.Decimal(12, 2)
  discount_type       String  @default("FIXED") @map("discount_type") @db.VarChar(32)
  discount_value      Decimal @default(0) @map("discount_value") @db.Decimal(12, 2)
  discount_calculated Decimal @default(0) @map("discount_calculated") @db.Decimal(12, 2)
  total    Decimal @db.Decimal(12, 2)
  grand_total Decimal @default(0) @map("grand_total") @db.Decimal(12, 2)

  notes String?
  template_snapshot Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items    InvoiceItem[]
  payments Payment[]
  email_logs EmailLog[]
  worker     Worker? @relation(fields: [workerId], references: [id], onDelete: SetNull)
  workerId   String? @map("worker_id") @db.VarChar(191)

  @@unique([user_id, invoice_number])
  @@index([user_id])
  @@index([customer_id])
  @@index([warehouse_id])
  @@index([status])
  @@index([due_date])
  @@index([user_id, createdAt])
  @@index([user_id, date])
  @@index([user_id, status, createdAt])
  @@index([workerId])
  @@map("invoices")
}

model RecurringInvoiceTemplate {
  id Int @id @default(autoincrement())

  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int

  customer    Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  customer_id Int

  title          String              @db.VarChar(191)
  is_active      Boolean             @default(true)
  frequency      RecurrenceFrequency @default(MONTHLY)
  interval_count Int                 @default(1)

  next_run_date DateTime
  last_run_date DateTime?
  due_in_days   Int       @default(7)

  discount Decimal @default(0) @db.Decimal(12, 2)
  notes    String?
  items    Json

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([user_id])
  @@index([customer_id])
  @@index([next_run_date])
  @@index([is_active, next_run_date])
  @@map("recurring_invoice_templates")
}

model InvoiceItem {
  id Int @id @default(autoincrement())

  invoice    Invoice @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  invoice_id Int

  product    Product? @relation(fields: [product_id], references: [id])
  product_id Int?

  name     String
  quantity Int
  nonInventoryItem Boolean @default(false) @map("non_inventory_item")

  price    Decimal  @map("unit_price") @db.Decimal(12, 2)
  tax_rate Decimal? @db.Decimal(5, 2)
  gst_type String   @default("NONE") @map("gst_type") @db.VarChar(32)
  base_amount Decimal @default(0) @map("base_amount") @db.Decimal(12, 2)
  gst_amount Decimal @default(0) @map("gst_amount") @db.Decimal(12, 2)
  cgst_amount Decimal @default(0) @map("cgst_amount") @db.Decimal(12, 2)
  sgst_amount Decimal @default(0) @map("sgst_amount") @db.Decimal(12, 2)
  igst_amount Decimal @default(0) @map("igst_amount") @db.Decimal(12, 2)

  total Decimal @map("line_total") @db.Decimal(12, 2)

  @@index([invoice_id])
  @@map("invoice_items")
}

model Payment {
  id Int @id @default(autoincrement())

  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int

  invoice    Invoice @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  invoice_id Int

  amount         Decimal       @db.Decimal(12, 2)
  method         PaymentMethod
  provider       String?       @db.VarChar(120)
  transaction_id String?       @db.VarChar(191)
  payment_idempotency_key String? @db.VarChar(191)

  reference String?
  notes String? @db.VarChar(500)
  cheque_number String? @db.VarChar(64)
  bank_name String? @db.VarChar(191)
  deposit_date DateTime?
  proof_url String? @db.VarChar(255)
  proof_file_name String? @db.VarChar(191)
  proof_file_path String? @db.VarChar(255)
  proof_file_id String? @db.VarChar(191)
  proof_mime_type String? @db.VarChar(191)
  proof_size Int?
  proof_uploaded_at DateTime?
  proof_uploaded_by String? @db.VarChar(191)
  verified_by String? @db.VarChar(191)

  paid_at    DateTime @default(now())
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([invoice_id])
  @@index([user_id])
  @@index([user_id, paid_at])
  @@unique([user_id, payment_idempotency_key])
  @@map("payments")
}

model AccessPayment {
  id String @id @default(cuid()) @db.VarChar(191)

  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int

  plan_id       String              @default("pro") @db.VarChar(32)
  billing_cycle String              @default("monthly") @db.VarChar(16)
  method        AccessPaymentMethod
  amount        Decimal             @db.Decimal(12, 2)
  status        AccessPaymentStatus @default(PENDING)

  name            String? @db.VarChar(191)
  utr             String? @unique @db.VarChar(64)
  screenshot_url  String?
  screenshot_path String?

  provider            String? @db.VarChar(120)
  provider_payment_id String? @unique @db.VarChar(191)
  provider_order_id   String? @unique @db.VarChar(191)
  provider_signature  String? @db.VarChar(191)
  provider_reference  String? @db.VarChar(191)
  metadata            Json?

  reviewed_by_admin_id    String?   @db.VarChar(191)
  reviewed_by_admin_email String?   @db.VarChar(191)
  reviewed_at             DateTime?
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt

  @@index([user_id, created_at])
  @@index([status, method, created_at])
  @@index([plan_id, billing_cycle])
  @@map("access_payments")
}

model Subscription {
  id String @id @default(cuid()) @db.VarChar(191)

  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int  @unique

  plan_id              SubscriptionPlan          @default(FREE)
  status               SubscriptionStatus        @default(ACTIVE)
  billing_cycle        SubscriptionBillingCycle?
  started_at           DateTime                  @default(now())
  trial_starts_at      DateTime?
  trial_ends_at        DateTime?
  current_period_start DateTime?
  current_period_end   DateTime?
  cancelled_at         DateTime?
  expires_at           DateTime?
  latest_payment_id    String?                   @db.VarChar(191)
  metadata             Json?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  usage SubscriptionUsage[]

  @@index([plan_id, status])
  @@map("subscriptions")
}

model SubscriptionUsage {
  id Int @id @default(autoincrement())

  subscription    Subscription @relation(fields: [subscription_id], references: [id], onDelete: Cascade)
  subscription_id String       @db.VarChar(191)

  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int

  period_key   String   @db.VarChar(16)
  period_start DateTime
  period_end   DateTime

  invoices_created  Int @default(0)
  products_created  Int @default(0)
  customers_created Int @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([subscription_id, period_key])
  @@index([user_id, period_start])
  @@map("subscription_usage")
}

model StockMovement {
  id Int @id @default(autoincrement())

  product    Product @relation(fields: [product_id], references: [id], onDelete: Cascade)
  product_id Int

  change Int
  reason StockReason

  note String?

  created_at DateTime @default(now())

  @@index([product_id])
  @@map("stock_movements")
}

model PasswordResetToken {
  id Int @id @default(autoincrement())

  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int

  token      String    @unique
  expires_at DateTime
  used_at    DateTime?

  created_at DateTime @default(now())

  @@index([user_id])
  @@map("password_reset_tokens")
}

model RefreshToken {
  id String @id @default(cuid()) @db.VarChar(191)

  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int

  token_hash String   @unique @db.VarChar(191)
  ip_address String?  @db.VarChar(64)
  user_agent String?  @db.VarChar(512)
  device_name String? @db.VarChar(191)
  expires_at DateTime
  last_used_at DateTime @default(now())
  revoked_at DateTime?
  revoked_reason String? @db.VarChar(64)
  created_at DateTime @default(now())

  @@index([user_id, expires_at])
  @@index([user_id, revoked_at, expires_at])
  @@map("refresh_tokens")
}

model AuditLog {
  id String @id @default(cuid()) @db.VarChar(191)

  user    User? @relation(fields: [user_id], references: [id], onDelete: SetNull)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int     @id @default(autoincrement())
  name              String  @db.VarChar(191)
  email             String  @unique @db.VarChar(191)
  password_hash     String?
  provider          String  @default("credentials")
  oauth_id          String?
  image             String?
  is_email_verified Boolean @default(false)

  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  customers                   Customer[]
  suppliers                   Supplier[]
  categories                  Category[]
  products                    Product[]
  warehouses                  Warehouse[]
  purchases                   Purchase[]
  sales                       Sale[]
  invoices                    Invoice[]
  recurring_invoice_templates RecurringInvoiceTemplate[]
  financial_goals             FinancialGoal[]
  payments                    Payment[]
  access_payments             AccessPayment[]
  subscription                Subscription?
  subscription_usage          SubscriptionUsage[]
  resets                      PasswordResetToken[]
  business_profile            BusinessProfile?
  user_templates              UserTemplate[]
  user_saved_templates        UserSavedTemplate[]
  export_logs                 ExportLog[]
  passkey_credentials         PasskeyCredential[]
  auth_challenges             AuthChallenge[]
  otp_codes                   OtpCode[]
  auth_events                 AuthEvent[]
  preferences                 UserPreference?

  session_version Int @default(0)

  @@map("users")
}

model UserPreference {
  id Int @id @default(autoincrement())

  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int  @unique

  language    String @default("en") @db.VarChar(10)
  currency    String @default("INR") @db.VarChar(10)
  date_format String @default("DD/MM/YYYY") @db.VarChar(32)

  notification_payment_reminders  Boolean @default(true)
  notification_low_stock_alerts   Boolean @default(true)
  notification_due_invoice_alerts Boolean @default(true)

  backup_auto_enabled Boolean @default(false)

  branding_template_id Int?
  branding_theme_color String? @db.VarChar(16)
  branding_terms       String?
  branding_signature   String? @db.VarChar(191)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("user_preferences")
}

model Admin {
  id        String   @id @default(cuid()) @db.VarChar(191)
  email     String   @unique @db.VarChar(191)
  password  String   @db.VarChar(191)
  role      String   @default("SUPER_ADMIN") @db.VarChar(32)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("admins")
}

model Business {
  id        String   @id @default(cuid()) @db.VarChar(191)
  name      String   @db.VarChar(191)
  ownerId   String   @unique @map("owner_id") @db.VarChar(191)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workers Worker[]

  @@map("businesses")
}

model Worker {
  id         String     @id @default(cuid()) @db.VarChar(191)
  email      String     @unique @db.VarChar(191)
  name       String     @db.VarChar(191)
  phone      String?    @unique @db.VarChar(191)
  password   String     @db.VarChar(191)
  role       WorkerRole @default(WORKER)
  businessId String     @map("business_id") @db.VarChar(191)
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@map("workers")
}

model BusinessProfile {
  id                   Int      @id @default(autoincrement())
  user                 User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id              Int      @unique
  business_name        String   @db.VarChar(191)
  address              String?
  address_line1        String?  @db.VarChar(191)
  city                 String?  @db.VarChar(191)
  state                String?  @db.VarChar(191)
  pincode              String?  @db.VarChar(10)
  phone                String?
  email                String?
  website              String?
  logo_url             String?
  tax_id               String?
  currency             String   @default("INR") @db.VarChar(10)
  show_logo_on_invoice Boolean  @default(true)
  show_tax_number      Boolean  @default(true)
  show_payment_qr      Boolean  @default(false)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  @@index([user_id])
  @@map("business_profiles")
}

model Template {
  id            Int      @id @default(autoincrement())
  name          String   @unique @db.VarChar(191)
  description   String?
  layout_config Json
  created_at    DateTime @default(now())

  sections             TemplateSection[]
  user_settings        UserTemplate[]
  user_saved_templates UserSavedTemplate[]

  @@map("templates")
}

model TemplateSection {
  id            Int      @id @default(autoincrement())
  template      Template @relation(fields: [template_id], references: [id], onDelete: Cascade)
  template_id   Int
  section_key   String   @db.VarChar(120)
  section_order Int
  is_default    Boolean  @default(true)

  @@index([template_id])
  @@map("template_sections")
}

model UserTemplate {
  id               Int      @id @default(autoincrement())
  user             User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id          Int
  template         Template @relation(fields: [template_id], references: [id], onDelete: Cascade)
  template_id      Int
  enabled_sections String[]
  theme_color      String?
  section_order    String[]
  design_config    Json?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@unique([user_id, template_id])
  @@index([user_id])
  @@index([template_id])
  @@map("user_templates")
}

model UserSavedTemplate {
  id               Int       @id @default(autoincrement())
  user             User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id          Int
  name             String    @db.VarChar(191)
  base_template    Template? @relation(fields: [base_template_id], references: [id], onDelete: SetNull)
  base_template_id Int?
  enabled_sections String[]
  section_order    String[]
  theme_color      String?
  design_config    Json?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  @@index([user_id])
  @@index([base_template_id])
  @@map("user_saved_templates")
}

model FinancialGoal {
  id                          Int       @id @default(autoincrement())
  user                        User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id                     Int
  title                       String    @db.VarChar(191)
  emoji                       String?   @db.VarChar(32)
  target_amount               Decimal   @db.Decimal(12, 2)
  current_amount              Decimal   @default(0) @db.Decimal(12, 2)
  monthly_contribution_target Decimal?  @db.Decimal(12, 2)
  target_date                 DateTime?
  created_at                  DateTime  @default(now())
  updated_at                  DateTime  @updatedAt

  @@index([user_id])
  @@map("financial_goals")
}

model Customer {
  id      Int  @id @default(autoincrement())
  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int

  name    String  @db.VarChar(191)
  email   String?
  phone   String?
  address String?

  customer_type   String   @default("individual") @db.VarChar(32)
  business_name   String?  @db.VarChar(191)
  gstin           String?  @db.VarChar(15)
  address_line1   String?  @db.VarChar(191)
  city            String?  @db.VarChar(191)
  state           String?  @db.VarChar(191)
  pincode         String?  @db.VarChar(10)
  notes           String?  @db.VarChar(500)
  credit_limit    Decimal? @db.Decimal(12, 2)
  payment_terms   String?  @db.VarChar(32)
  opening_balance Decimal  @default(0) @db.Decimal(12, 2)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  invoices                    Invoice[]
  recurring_invoice_templates RecurringInvoiceTemplate[]
  sales                       Sale[]

  @@index([user_id])
  @@map("customers")
}

model Supplier {
  id      Int  @id @default(autoincrement())
  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int

  name       String
  email      String?
  phone      String?
  address    String?
  categories String[] @default([])

  business_name   String? @db.VarChar(191)
  gstin           String? @db.VarChar(15)
  pan             String? @db.VarChar(10)
  address_line1   String? @db.VarChar(191)
  city            String? @db.VarChar(191)
  state           String? @db.VarChar(191)
  pincode         String? @db.VarChar(10)
  payment_terms   String? @db.VarChar(32)
  opening_balance Decimal @default(0) @db.Decimal(12, 2)
  notes           String? @db.VarChar(500)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  purchases Purchase[]

  @@index([user_id])
  @@map("suppliers")
}

model Category {
  id Int @id @default(autoincrement())

  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int

  name String

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  products Product[]

  @@unique([user_id, name])
  @@index([user_id])
  @@map("categories")
}

model Product {
  id Int @id @default(autoincrement())

  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int

  category    Category? @relation(fields: [category_id], references: [id], onDelete: SetNull)
  category_id Int?

  name    String
  sku     String
  barcode String?

  price Decimal  @db.Decimal(12, 2)
  cost  Decimal? @db.Decimal(12, 2)

  gst_rate Decimal @default(18) @db.Decimal(5, 2)

  stock_on_hand Int @default(0)
  reorder_level Int @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  purchaseItems PurchaseItem[]
  saleItems     SaleItem[]
  invoiceItems  InvoiceItem[]
  movements     StockMovement[]
  inventories   Inventory[]

  @@unique([user_id, barcode])
  @@unique([user_id, sku])
  @@index([user_id])
  @@index([category_id])
  @@index([user_id, name])
  @@index([user_id, category_id])
  @@map("products")
}

model Warehouse {
  id Int @id @default(autoincrement())

  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int

  name     String
  location String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  inventories Inventory[]
  purchases   Purchase[]

  @@index([user_id])
  @@map("warehouses")
}

model Inventory {
  id Int @id @default(autoincrement())

  warehouse    Warehouse @relation(fields: [warehouse_id], references: [id], onDelete: Cascade)
  warehouse_id Int

  product    Product @relation(fields: [product_id], references: [id], onDelete: Cascade)
  product_id Int

  quantity Int @default(0)

  @@unique([warehouse_id, product_id])
  @@map("inventories")
}

model Purchase {
  id Int @id @default(autoincrement())

  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int

  supplier    Supplier? @relation(fields: [supplier_id], references: [id], onDelete: SetNull)
  supplier_id Int?

  warehouse    Warehouse? @relation(fields: [warehouse_id], references: [id], onDelete: SetNull)
  warehouse_id Int?

  purchase_date DateTime @default(now())

  subtotal      Decimal        @db.Decimal(12, 2)
  tax           Decimal        @db.Decimal(12, 2)
  total         Decimal        @db.Decimal(12, 2)
  totalAmount   Decimal        @default(0) @map("total_amount") @db.Decimal(12, 2)
  paidAmount    Decimal        @default(0) @map("paid_amount") @db.Decimal(12, 2)
  pendingAmount Decimal        @default(0) @map("pending_amount") @db.Decimal(12, 2)
  paymentStatus PaymentStatus  @default(UNPAID) @map("payment_status")
  paymentDate   DateTime?      @map("payment_date")
  paymentMethod PaymentMethod? @map("payment_method")

  notes String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  items PurchaseItem[]

  @@index([user_id])
  @@index([supplier_id])
  @@index([warehouse_id])
  @@map("purchases")
}

model PurchaseItem {
  id Int @id @default(autoincrement())

  purchase    Purchase @relation(fields: [purchase_id], references: [id], onDelete: Cascade)
  purchase_id Int

  product    Product? @relation(fields: [product_id], references: [id])
  product_id Int?

  name       String
  quantity   Int
  unit_cost  Decimal  @db.Decimal(12, 2)
  tax_rate   Decimal? @db.Decimal(5, 2)
  line_total Decimal  @db.Decimal(12, 2)

  @@index([purchase_id])
  @@map("purchase_items")
}

model Sale {
  id Int @id @default(autoincrement())

  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int

  customer    Customer? @relation(fields: [customer_id], references: [id], onDelete: SetNull)
  customer_id Int?

  status SaleStatus @default(COMPLETED)

  sale_date DateTime @default(now())

  subtotal      Decimal        @db.Decimal(12, 2)
  tax           Decimal        @db.Decimal(12, 2)
  total         Decimal        @db.Decimal(12, 2)
  totalAmount   Decimal        @default(0) @map("total_amount") @db.Decimal(12, 2)
  paidAmount    Decimal        @default(0) @map("paid_amount") @db.Decimal(12, 2)
  pendingAmount Decimal        @default(0) @map("pending_amount") @db.Decimal(12, 2)
  paymentStatus PaymentStatus  @default(UNPAID) @map("payment_status")
  paymentDate   DateTime?      @map("payment_date")
  paymentMethod PaymentMethod? @map("payment_method")

  notes String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  items SaleItem[]

  @@index([user_id])
  @@index([customer_id])
  @@index([user_id, sale_date])
  @@map("sales")
}

model SaleItem {
  id Int @id @default(autoincrement())

  sale    Sale @relation(fields: [sale_id], references: [id], onDelete: Cascade)
  sale_id Int

  product    Product? @relation(fields: [product_id], references: [id])
  product_id Int?

  name     String
  quantity Int

  unit_price Decimal  @db.Decimal(12, 2)
  tax_rate   Decimal? @db.Decimal(5, 2)

  line_total Decimal @db.Decimal(12, 2)

  @@index([sale_id])
  @@map("sale_items")
}

model Invoice {
  id Int @id @default(autoincrement())

  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int

  customer    Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  customer_id Int

  invoice_number String @db.VarChar(32)

  status InvoiceStatus @default(DRAFT)

  date     DateTime  @default(now()) @map("issue_date")
  due_date DateTime?

  subtotal Decimal @db.Decimal(12, 2)
  tax      Decimal @db.Decimal(12, 2)
  discount Decimal @default(0) @db.Decimal(12, 2)
  total    Decimal @db.Decimal(12, 2)

  notes String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items    InvoiceItem[]
  payments Payment[]

  @@unique([user_id, invoice_number])
  @@index([user_id])
  @@index([customer_id])
  @@index([status])
  @@index([due_date])
  @@map("invoices")
}

model RecurringInvoiceTemplate {
  id Int @id @default(autoincrement())

  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int

  customer    Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  customer_id Int

  title          String              @db.VarChar(191)
  is_active      Boolean             @default(true)
  frequency      RecurrenceFrequency @default(MONTHLY)
  interval_count Int                 @default(1)

  next_run_date DateTime
  last_run_date DateTime?
  due_in_days   Int       @default(7)

  discount Decimal @default(0) @db.Decimal(12, 2)
  notes    String?
  items    Json

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([user_id])
  @@index([customer_id])
  @@index([next_run_date])
  @@index([is_active, next_run_date])
  @@map("recurring_invoice_templates")
}

model InvoiceItem {
  id Int @id @default(autoincrement())

  invoice    Invoice @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  invoice_id Int

  product    Product? @relation(fields: [product_id], references: [id])
  product_id Int?

  name     String
  quantity Int

  price    Decimal  @map("unit_price") @db.Decimal(12, 2)
  tax_rate Decimal? @db.Decimal(5, 2)

  total Decimal @map("line_total") @db.Decimal(12, 2)

  @@index([invoice_id])
  @@map("invoice_items")
}

model Payment {
  id Int @id @default(autoincrement())

  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int

  invoice    Invoice @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  invoice_id Int

  amount         Decimal       @db.Decimal(12, 2)
  method         PaymentMethod
  provider       String?       @db.VarChar(120)
  transaction_id String?       @db.VarChar(191)

  reference String?

  paid_at    DateTime @default(now())
  created_at DateTime @default(now())

  @@index([invoice_id])
  @@index([user_id])
  @@map("payments")
}

model AccessPayment {
  id String @id @default(cuid()) @db.VarChar(191)

  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int

  plan_id       String              @default("pro") @db.VarChar(32)
  billing_cycle String              @default("monthly") @db.VarChar(16)
  method        AccessPaymentMethod
  amount        Decimal             @db.Decimal(12, 2)
  status        AccessPaymentStatus @default(PENDING)

  name            String? @db.VarChar(191)
  utr             String? @unique @db.VarChar(64)
  screenshot_url  String?
  screenshot_path String?

  provider            String? @db.VarChar(120)
  provider_payment_id String? @unique @db.VarChar(191)
  provider_order_id   String? @unique @db.VarChar(191)
  provider_signature  String? @db.VarChar(191)
  provider_reference  String? @db.VarChar(191)
  metadata            Json?

  reviewed_by_admin_id    String?   @db.VarChar(191)
  reviewed_by_admin_email String?   @db.VarChar(191)
  reviewed_at             DateTime?
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt

  @@index([user_id, created_at])
  @@index([status, method, created_at])
  @@index([plan_id, billing_cycle])
  @@map("access_payments")
}

model Subscription {
  id String @id @default(cuid()) @db.VarChar(191)

  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int  @unique

  plan_id              SubscriptionPlan          @default(FREE)
  status               SubscriptionStatus        @default(ACTIVE)
  billing_cycle        SubscriptionBillingCycle?
  started_at           DateTime                  @default(now())
  trial_starts_at      DateTime?
  trial_ends_at        DateTime?
  current_period_start DateTime?
  current_period_end   DateTime?
  cancelled_at         DateTime?
  expires_at           DateTime?
  latest_payment_id    String?                   @db.VarChar(191)
  metadata             Json?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  usage SubscriptionUsage[]

  @@index([plan_id, status])
  @@map("subscriptions")
}

model SubscriptionUsage {
  id Int @id @default(autoincrement())

  subscription    Subscription @relation(fields: [subscription_id], references: [id], onDelete: Cascade)
  subscription_id String       @db.VarChar(191)

  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int

  period_key   String   @db.VarChar(16)
  period_start DateTime
  period_end   DateTime

  invoices_created  Int @default(0)
  products_created  Int @default(0)
  customers_created Int @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([subscription_id, period_key])
  @@index([user_id, period_start])
  @@map("subscription_usage")
}

model StockMovement {
  id Int @id @default(autoincrement())

  product    Product @relation(fields: [product_id], references: [id], onDelete: Cascade)
  product_id Int

  change Int
  reason StockReason

  note String?

  created_at DateTime @default(now())

  @@index([product_id])
  @@map("stock_movements")
}

model PasswordResetToken {
  id Int @id @default(autoincrement())

  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int

  token      String    @unique
  expires_at DateTime
  used_at    DateTime?

  created_at DateTime @default(now())

  @@index([user_id])
  @@map("password_reset_tokens")
}

model ExportLog {
  id Int @id @default(autoincrement())

  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int

  actor_id String  @db.VarChar(191)
  resource String  @db.VarChar(64)
  format   String  @db.VarChar(16)
  scope    String  @db.VarChar(16)
  delivery String  @default("download") @db.VarChar(16)
  email    String?

  filters        Json?
  selected_count Int      @default(0)
  exported_count Int      @default(0)
  created_at     DateTime @default(now())

  @@index([user_id, created_at])
  @@map("export_logs")
}

model PasskeyCredential {
  id Int @id @default(autoincrement())

  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int

  label         String    @db.VarChar(191)
  credential_id String    @unique @db.VarChar(512)
  public_key    String
  counter       Int       @default(0)
  device_type   String    @default("multiDevice") @db.VarChar(32)
  backed_up     Boolean   @default(false)
  transports    String[]
  last_used_at  DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  @@index([user_id, created_at])
  @@map("passkey_credentials")
}

model AuthChallenge {
  id Int @id @default(autoincrement())

  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int

  flow        AuthChallengeFlow
  challenge   String            @unique @db.VarChar(255)
  expires_at  DateTime
  consumed_at DateTime?
  created_at  DateTime          @default(now())

  @@index([user_id, flow, created_at])
  @@map("auth_challenges")
}

model OtpCode {
  id Int @id @default(autoincrement())

  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int

  purpose             OtpPurpose @default(LOGIN)
  channel             OtpChannel @default(EMAIL)
  code_hash           String     @db.VarChar(191)
  expires_at          DateTime
  resend_available_at DateTime
  attempts            Int        @default(0)
  max_attempts        Int        @default(3)
  consumed_at         DateTime?
  created_at          DateTime   @default(now())

  @@index([user_id, purpose, created_at])
  @@map("otp_codes")
}

model AuthEvent {
  id Int @id @default(autoincrement())

  user    User? @relation(fields: [user_id], references: [id], onDelete: SetNull)
  user_id Int?

  actor_type String     @db.VarChar(32)
  method     AuthMethod
  success    Boolean    @default(true)
  ip_address String?    @db.VarChar(64)
  user_agent String?    @db.VarChar(512)
  metadata   Json?
  created_at DateTime   @default(now())

  @@index([user_id, created_at])
  @@index([method, created_at])
  @@map("auth_events")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  UPI
  CHEQUE
  OTHER
}

enum PaymentStatus {
  PAID

  @@index([user_id, expires_at])
  @@map("email_verification_tokens")
}

model EmailLog {
  id String @id @default(cuid()) @db.VarChar(191)

  user    User? @relation(fields: [user_id], references: [id], onDelete: SetNull)
  user_id Int?

  invoice    Invoice? @relation(fields: [invoice_id], references: [id], onDelete: SetNull)
  invoice_id Int?

  customer    Customer? @relation(fields: [customer_id], references: [id], onDelete: SetNull)
  customer_id Int?

  type                String              @db.VarChar(64)
  status              EmailDeliveryStatus @default(PENDING)
  recipient_email     String              @db.VarChar(191)
  subject             String?             @db.VarChar(191)
  provider_message_id String?             @db.VarChar(191)
  error_message       String?             @db.VarChar(1000)
  metadata            Json?
  sent_at             DateTime?
  created_at          DateTime            @default(now())
  updated_at          DateTime            @updatedAt

  @@index([user_id, created_at])
  @@index([invoice_id, type, created_at])
  @@index([customer_id, created_at])
  @@index([type, status, created_at])
  @@index([recipient_email, created_at])
  @@map("email_logs")
}

model UploadedFile {
  id String @id @default(cuid()) @db.VarChar(191)


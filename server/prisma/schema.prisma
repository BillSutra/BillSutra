  actor_id      String  @db.VarChar(191)
  actor_type    String  @db.VarChar(32)
  action        String  @db.VarChar(64)
  resource_type String  @db.VarChar(64)
  resource_id   String? @db.VarChar(191)
  status        String  @default("SUCCESS") @db.VarChar(16)
  ip_address    String? @db.VarChar(64)
  user_agent    String? @db.VarChar(512)
  metadata      Json?
  created_at    DateTime @default(now())

  @@index([user_id, created_at])
  @@index([resource_type, resource_id, created_at])
  @@index([action, created_at])
  @@map("audit_logs")
}

model EmailVerificationToken {
  id String @id @default(cuid()) @db.VarChar(191)

  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)

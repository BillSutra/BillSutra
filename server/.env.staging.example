APP_ENV=staging
NODE_ENV=production
PORT=8000
TRUST_PROXY=1
ENABLE_SCHEDULER=false
GRACEFUL_SHUTDOWN_TIMEOUT_MS=15000
UPLOADS_ROOT=/var/lib/billsutra-staging/uploads

FRONTEND_URL=https://staging.billsutra.com
APP_URL=https://staging.billsutra.com
BACKEND_URL=https://api-staging.billsutra.com
CORS_ORIGINS=https://staging.billsutra.com

USE_SECURE_AUTH=true
USE_COOKIE_AUTH=true
USE_DYNAMIC_STATUS=true
AUTH_COOKIE_SECURE=auto
AUTH_COOKIE_SAMESITE=lax

USE_REDIS_CACHE=true
USE_REDIS_RATE_LIMIT=true
USE_QUEUE=true

SENTRY_DSN=
SENTRY_ENVIRONMENT=staging
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.2
SENTRY_SLOW_REQUEST_THRESHOLD_MS=1200

WEBAUTHN_ORIGIN=https://staging.billsutra.com
WEBAUTHN_RP_ID=staging.billsutra.com
WEBAUTHN_RP_NAME=BillSutra Staging

APP_ENV=production
NODE_ENV=production
PORT=8000
TRUST_PROXY=1
ENABLE_SCHEDULER=false
GRACEFUL_SHUTDOWN_TIMEOUT_MS=15000
UPLOADS_ROOT=/var/lib/billsutra/uploads

FRONTEND_URL=https://billsutra.com
APP_URL=https://billsutra.com
BACKEND_URL=https://api.billsutra.com
CORS_ORIGINS=https://billsutra.com,https://www.billsutra.com

USE_SECURE_AUTH=true
USE_COOKIE_AUTH=true
USE_DYNAMIC_STATUS=true

USE_REDIS_CACHE=true
USE_REDIS_RATE_LIMIT=true
USE_QUEUE=true

WEBAUTHN_ORIGIN=https://billsutra.com
WEBAUTHN_RP_ID=billsutra.com
WEBAUTHN_RP_NAME=BillSutra

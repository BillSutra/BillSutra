# BillSutra backend environment template
# Copy this file to server/.env and replace placeholders with real values.

# ------------------------------
# Core runtime
# ------------------------------
APP_ENV=production
NODE_ENV=production
PORT=8000
TRUST_PROXY=1
ENABLE_SCHEDULER=true
GRACEFUL_SHUTDOWN_TIMEOUT_MS=15000
UPLOADS_ROOT=./uploads

# Prisma PostgreSQL connection.
# URL-encode reserved characters in the username/password.
# Examples: @ => %40, / => %2F, ? => %3F, # => %23
#
# Supabase + Prisma recommended setup:
# - DATABASE_URL: runtime URL used by the app. Use the Supabase transaction pooler on :6543 with pgbouncer=true.
# - DIRECT_URL: Prisma CLI URL used by prisma migrate / prisma db push. Use the direct DB host or the Supabase session pooler on :5432.
# - If you create a dedicated Prisma role in Supabase, replace `postgres` with `prisma` in both usernames.
DATABASE_URL=postgresql://postgres.project-ref:pa%24%24word@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&pool_timeout=30&sslmode=require
DIRECT_URL=postgresql://postgres.project-ref:pa%24%24word@aws-0-region.pooler.supabase.com:5432/postgres?sslmode=require

# Required auth secrets in production (32+ chars).
# In development, missing/weak secrets get safe runtime fallbacks so startup stays beginner-friendly.
# Quote values if they contain `#`, spaces, or other dotenv-sensitive characters.
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
ACCESS_TOKEN_SECRET=replace-with-a-separate-long-random-secret-at-least-32-chars
REFRESH_TOKEN_SECRET=replace-with-another-long-random-secret-at-least-32-chars

# Public app URLs
FRONTEND_URL=https://app.example.com
APP_URL=https://app.example.com
BACKEND_URL=https://api.example.com
CORS_ORIGIN=https://app.example.com
CORS_ORIGINS=https://app.example.com,https://www.example.com

# Auth mode flags
USE_SECURE_AUTH=true
USE_COOKIE_AUTH=true
USE_DYNAMIC_STATUS=true

# ------------------------------
# Upstash Redis
# ------------------------------
# Shared Redis for cache, realtime throttling, and API rate limiting.
USE_REDIS_CACHE=true
USE_REDIS_RATE_LIMIT=true
UPSTASH_REDIS_REST_URL=https://your-cache-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# BullMQ / background queues require a TCP Redis connection.
# Upstash REST alone is not enough for BullMQ.
USE_QUEUE=false
REDIS_URL=rediss://default:password@your-queue-db.upstash.io:6379

# Optional TCP field-level overrides/aliases (used when REDIS_URL is omitted).
REDIS_HOST=
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=
REDIS_TOKEN=
REDIS_DB=0
REDIS_TLS=true

# ------------------------------
# Email / SMTP
# ------------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
EMAIL_FROM_NAME=BillSutra
EMAIL_ATTACHMENT_MAX_BYTES=10485760

# ------------------------------
# Payments
# ------------------------------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
UPI_ID=
UPI_PAYEE_NAME=BillSutra

# ------------------------------
# AI / assistant
# ------------------------------
OPENAI_API_KEY=
OPENAI_LANDING_ASSISTANT_MODEL=gpt-4.1-mini

# ------------------------------
# WebAuthn / passkeys
# ------------------------------
WEBAUTHN_ORIGIN=https://app.example.com
WEBAUTHN_RP_ID=app.example.com
WEBAUTHN_RP_NAME=BillSutra

# ------------------------------
# Face recognition / encryption
# ------------------------------
FACE_SERVICE_URL=http://localhost:5001
FACE_SERVICE_API_KEY=
FACE_RECOGNITION_TIMEOUT_MS=15000
FACE_ENCRYPTION_KEY=
DATA_ENCRYPTION_KEY=
FIELD_ENCRYPTION_KEY=
SECURE_FILE_SIGNING_SECRET=

# ------------------------------
# Observability
# ------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_SLOW_REQUEST_THRESHOLD_MS=1200
SENTRY_RELEASE=

# ------------------------------
# Optional cache / job tuning
# ------------------------------
INVENTORY_INSIGHTS_CACHE_MS=21600000
NOTIFICATION_SYNC_TTL_MS=45000
DASHBOARD_METRICS_CACHE_MS=30000
DASHBOARD_METRICS_CACHE_TTL_SECONDS=30
DASHBOARD_ENDPOINT_CACHE_TTL_SECONDS=30
DASHBOARD_OVERVIEW_CACHE_MS=30000
PRISMA_LOG_QUERIES=false
PRISMA_SLOW_QUERY_MS=250
INVENTORY_RECONCILIATION_MODE=log_only
